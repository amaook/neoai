{
  "name": "neo",
  "version": "0.8.5",
  "description": "A local desktop AI agent with configurable API providers and models.",
  "author": "neo",
  "private": true,
  "type": "module",
  "main": "electron/main.mjs",
  "scripts": {
    "start": "node server.mjs",
    "dev": "node server.mjs",
    "test": "vitest run",
    "test:watch": "vitest",
    "desktop": "electron .",
    "package:dir": "electron-builder --dir --publish never",
    "package:mac": "electron-builder --mac dmg --publish never",
    "package:win": "electron-builder --win nsis zip --x64 --publish never",
    "release:mac": "electron-builder --mac dmg zip --publish always",
    "release:win": "electron-builder --win nsis zip --x64 --publish always"
  },
  "engines": {
    "node": ">=18"
  },
  "build": {
    "appId": "ai.neo.desktop",
    "productName": "neo",
    "artifactName": "neo-${version}-${os}-${arch}.${ext}",
    "icon": "build/icon.png",
    "directories": {
      "output": "outputs/desktop"
    },
    "publish": [
      {
        "provider": "github",
        "owner": "amaook",
        "repo": "neoai",
        "releaseType": "release"
      }
    ],
    "files": [
      "electron/**/*",
      "public/**/*",
      "server/**/*",
      "tools/**/*",
      "build/icon.png",
      "server.mjs",
      "package.json"
    ],
    "mac": {
      "category": "public.app-category.developer-tools",
      "icon": "build/icon.icns",
      "target": [
        "dmg"
      ]
    },
    "win": {
      "icon": "build/icon.ico",
      "target": [
        "nsis",
        "zip"
      ]
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "perMachine": false,
      "include": "build/installer.nsh",
      "uninstallDisplayName": "neo ${version}"
    }
  },
  "devDependencies": {
    "electron": "^42.3.0",
    "electron-builder": "^26.8.1",
    "vitest": "^2.0.0"
  },
  "dependencies": {
    "@napi-rs/canvas": "^0.1.80",
    "electron-updater": "^6.8.3",
    "mammoth": "^1.12.0",
    "pdf-parse": "^2.4.5",
    "read-excel-file": "^9.0.10",
    "write-excel-file": "^4.0.7"
  }
}
